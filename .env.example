# Neural Day Trader Platform - Environment Variables

# ===== SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ===== METAAPI (MT5) =====
# Token obtido em: https://app.metaapi.cloud/token
METAAPI_TOKEN=eyJhbGciOiJSUzUxMiIsInR5cCI6IkpXVCJ9...

# ===== GOOGLE CLOUD (OPCIONAL) =====
# Para Text-to-Speech e Speech-to-Text
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# ===== ADMIN ACCESS =====
# Email do admin que terá acesso total
ADMIN_EMAIL=your-admin@email.com
